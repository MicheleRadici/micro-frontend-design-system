{
  "name": "micro-frontend-design-system",
  "version": "1.0.0",
  "private": true,
  "description": "Two single-spa React apps sharing one runtime-loaded design system, no version lock.",
  "workspaces": [
    "root-config",
    "design-system",
    "accounts",
    "payments"
  ],
  "scripts": {
    "start": "concurrently -k -n root,ds,accounts,payments -c blue,magenta,green,yellow \"npm:start:root\" \"npm:start:ds\" \"npm:start:accounts\" \"npm:start:payments\"",
    "start:root": "npm start -w root-config",
    "start:ds": "npm start -w design-system",
    "start:accounts": "npm start -w accounts",
    "start:payments": "npm start -w payments",
    "build": "npm run build -w design-system && npm run build -w accounts && npm run build -w payments && npm run build -w root-config"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "babel-loader": "^9.1.3",
    "concurrently": "^9.1.0",
    "html-webpack-plugin": "^5.6.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "single-spa": "^6.0.3",
    "single-spa-react": "^6.0.2"
  }
}
