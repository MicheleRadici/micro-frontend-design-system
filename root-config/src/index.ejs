<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Micro-frontend · runtime design system</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style>
      body { margin: 0; font-family: system-ui, sans-serif; color: #e6edf3; background: #0d1117; }
      header { padding: 16px 24px; border-bottom: 1px solid #30363d; }
      nav a {
        display: inline-block; margin-right: 12px; padding: 6px 14px;
        text-decoration: none; color: #8b949e; font-weight: 600;
        border-radius: 8px; border: 1px solid transparent; transition: background .12s, color .12s;
      }
      nav a:hover { background: #161b22; color: #e6edf3; }
      nav a[href="/accounts"].active { background: #1f6feb; color: #fff; }
      nav a[href="/payments"].active { background: #238636; color: #fff; }
      .hint { color: #8b949e; font-size: 13px; margin-top: 4px; }
      main { min-height: 200px; }
    </style>

    <!--
      The import-map is the single source of truth for WHERE each module lives.
      react / react-dom are shared singletons (one instance for every app).
      @mr/design-system is the LIVE design system, both apps point at the same
      URL, so a redeploy of it updates both apps with no rebuild.
    -->
    <script type="systemjs-importmap">
      {
        "imports": {
          "react": "https://cdn.jsdelivr.net/npm/react@18.3.1/umd/react.production.min.js",
          "react-dom": "https://cdn.jsdelivr.net/npm/react-dom@18.3.1/umd/react-dom.production.min.js",
          "react-dom/client": "https://cdn.jsdelivr.net/npm/react-dom@18.3.1/umd/react-dom.production.min.js",
          "single-spa": "https://cdn.jsdelivr.net/npm/single-spa@6.0.3/lib/es2015/system/single-spa.min.js",
          "@mr/root-config": "/mr-root-config.js",
          "@mr/design-system": "http://localhost:8502/mr-design-system.js",
          "@mr/accounts": "http://localhost:8500/mr-accounts.js",
          "@mr/payments": "http://localhost:8501/mr-payments.js"
        }
      }
    </script>

    <script src="https://cdn.jsdelivr.net/npm/systemjs@6.15.1/dist/system.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/systemjs@6.15.1/dist/extras/amd.min.js"></script>
  </head>
  <body>
    <header>
      <nav>
        <a href="/accounts">Accounts</a>
        <a href="/payments">Payments</a>
      </nav>
      <div class="hint">
        Two independently-built apps, one runtime-loaded design system. Switch
        routes, the shell stays mounted, each app loads on demand.
      </div>
    </header>

    <main id="single-spa-root"></main>

    <script>
      System.import("@mr/root-config");
    </script>

    <script>
      // Highlight the nav item for the route we're on, so it's always clear
      // which app is mounted. Runs on load and on back/forward navigation.
      (function () {
        function setActiveNav() {
          var path = window.location.pathname;
          document.querySelectorAll("nav a").forEach(function (a) {
            var href = a.getAttribute("href");
            a.classList.toggle("active", path === href || path.indexOf(href + "/") === 0);
          });
        }
        setActiveNav();
        window.addEventListener("popstate", setActiveNav);
        document.querySelectorAll("nav a").forEach(function (a) {
          a.addEventListener("click", function () { setTimeout(setActiveNav, 0); });
        });
      })();
    </script>
  </body>
</html>
